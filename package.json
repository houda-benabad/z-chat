{
  "name": "z-chat",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "clean": "turbo clean",
    "lint": "eslint apps packages --max-warnings=0",
    "format": "prettier --write apps packages",
    "format:check": "prettier --check apps packages",
    "dev:server": "turbo dev --filter=@z-chat/server",
    "dev:mobile": "turbo dev --filter=@z-chat/mobile"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "prettier": "3.8.1",
    "turbo": "2"
  },
  "packageManager": "npm@11.11.1",
  "version": "1.0.0",
  "optionalDependencies": {
    "react-native-worklets": "^0.5.1"
  }
}
