{
  "expo": {
    "name": "z.chat",
    "slug": "z-chat",
    "version": "0.0.1",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "newArchEnabled": true,
    "icon": "./assets/default-avatar.png",
    "userInterfaceStyle": "light",
    "scheme": "zchat",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zsystems.zchat",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow z.chat to access the camera for video calls.",
        "NSMicrophoneUsageDescription": "Allow z.chat to access the microphone for voice and video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.zsystems.zchat",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-av",
        {
          "microphonePermission": "Allow z.chat to record audio for voice messages."
        }
      ],
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/default-avatar.png",
          "color": "#E46C53"
        }
      ],
      "@sentry/react-native/expo",
      "expo-video",
      "expo-dev-client"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3af539f2-fdd6-41cb-b80f-1f000ee1466f"
      }
    },
    "owner": "hobenaba"
  }
}
