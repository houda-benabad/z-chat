{
  "expo": {
    "name": "z.chat",
    "slug": "z-chat",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "zchat",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zsystems.zchat"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.zsystems.zchat"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
