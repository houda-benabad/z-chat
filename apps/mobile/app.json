{
  "expo": {
    "name": "z.chat",
    "slug": "z-chat",
    "version": "0.0.1",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "newArchEnabled": false,
    "icon": "./assets/default-avatar.png",
    "userInterfaceStyle": "light",
    "scheme": "zchat",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zsystems.zchat"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.zsystems.zchat"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-image-picker",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/default-avatar.png",
          "color": "#E46C53"
        }
      ],
      "@sentry/react-native/expo"
    ]
  }
}
