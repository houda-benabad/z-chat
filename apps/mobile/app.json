{
  "expo": {
    "name": "z.chat",
    "slug": "z-chat",
    "version": "0.0.1",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "zchat",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E46C53"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zsystems.zchat",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "Allow z.chat to access your contacts to find friends already on the app.",
        "NSCameraUsageDescription": "Allow z.chat to access the camera for video calls.",
        "NSMicrophoneUsageDescription": "Allow z.chat to access the microphone for voice and video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.zsystems.zchat",
      "navigationBar": {
        "backgroundColor": "#FFFFFF",
        "barStyle": "dark-content"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-font",
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow z.chat to access your contacts to find friends already on the app."
        }
      ],
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E46C53"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E46C53"
        }
      ],
      "@sentry/react-native/expo",
      "expo-video",
      "expo-dev-client",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow z.chat to record audio for voice messages."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3af539f2-fdd6-41cb-b80f-1f000ee1466f"
      }
    },
    "owner": "hobenaba",
    "updates": {
      "url": "https://u.expo.dev/3af539f2-fdd6-41cb-b80f-1f000ee1466f"
    }
  }
}
