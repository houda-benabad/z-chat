generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(uuid())
  phone         String             @unique
  name          String?
  about         String?
  avatar        String?
  publicKey     String?            @map("public_key")
  lastSeen      DateTime           @default(now()) @map("last_seen")
  isOnline      Boolean            @default(false) @map("is_online")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  participants  ChatParticipant[]
  sentMessages  Message[]          @relation("SentMessages")
  contacts      Contact[]          @relation("UserContacts")
  contactOf     Contact[]          @relation("ContactUser")
  settings      UserSettings?
  blockedUsers  BlockedUser[]      @relation("UserBlocked")
  blockedBy     BlockedUser[]      @relation("BlockedByUser")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Chat {
  id           String            @id @default(uuid())
  type         String            @default("direct") // "direct" | "group"
  name         String?
  description  String?
  avatar       String?
  createdBy    String?           @map("created_by")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  participants ChatParticipant[]
  messages     Message[]

  @@map("chats")
}

model ChatParticipant {
  id                String    @id @default(uuid())
  chatId            String    @map("chat_id")
  userId            String    @map("user_id")
  role              String    @default("member") // "admin" | "member"
  joinedAt          DateTime  @default(now()) @map("joined_at")
  lastReadMessageId String?   @map("last_read_message_id")
  isPinned          Boolean   @default(false) @map("is_pinned")
  deletedAt         DateTime? @map("deleted_at")
  encryptedGroupKey String?   @map("encrypted_group_key")
  groupKeyVersion   Int       @default(0) @map("group_key_version")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model Message {
  id           String    @id @default(uuid())
  chatId       String    @map("chat_id")
  senderId     String    @map("sender_id")
  type         String    @default("text") // "text" | "image" | "video" | "audio" | "document" | "voice_note"
  content      String?
  mediaUrl     String?   @map("media_url")
  replyToId    String?   @map("reply_to_id")
  isForwarded  Boolean   @default(false) @map("is_forwarded")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  disappearsAt DateTime? @map("disappears_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  chat    Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender  User     @relation("SentMessages", fields: [senderId], references: [id])
  replyTo Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies Message[] @relation("MessageReplies")

  @@index([chatId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Contact {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  contactUserId String   @map("contact_user_id")
  nickname      String?
  createdAt     DateTime @default(now()) @map("created_at")

  user        User @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contactUser User @relation("ContactUser", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([userId, contactUserId])
  @@index([userId])
  @@map("contacts")
}

model UserSettings {
  id                     String   @id @default(uuid())
  userId                 String   @unique @map("user_id")
  lastSeenVisibility     String   @default("everyone") @map("last_seen_visibility")
  profilePhotoVisibility String   @default("everyone") @map("profile_photo_visibility")
  aboutVisibility        String   @default("everyone") @map("about_visibility")
  readReceipts           Boolean  @default(true) @map("read_receipts")
  defaultDisappearTimer  Int      @default(0) @map("default_disappear_timer")
  messageNotifications   Boolean  @default(true) @map("message_notifications")
  groupNotifications     Boolean  @default(true) @map("group_notifications")
  callNotifications      Boolean  @default(true) @map("call_notifications")
  notificationSound      Boolean  @default(true) @map("notification_sound")
  notificationVibrate    Boolean  @default(true) @map("notification_vibrate")
  notificationPreview    Boolean  @default(true) @map("notification_preview")
  theme                  String   @default("system")
  accentColor            String   @default("#E46C53") @map("accent_color")
  fontSize               String   @default("medium") @map("font_size")
  autoDownloadPhotos     Boolean  @default(true) @map("auto_download_photos")
  autoDownloadVideos     Boolean  @default(false) @map("auto_download_videos")
  autoDownloadDocuments  Boolean  @default(false) @map("auto_download_documents")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model BlockedUser {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  blockedUserId String   @map("blocked_user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User @relation("UserBlocked", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser User @relation("BlockedByUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([userId])
  @@map("blocked_users")
}
