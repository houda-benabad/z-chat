DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zchat?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
ALLOWED_ORIGIN=http://YOUR_SERVER_IP:8081
UPLOAD_BASE_URL=http://YOUR_SERVER_IP:3000

# Twilio SMS (required in production, optional in development)
TWILIO_ACCOUNT_SID=your-twilio-account-sid #ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
ls
